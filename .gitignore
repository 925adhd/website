# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# original site backup
/_old_site/

# client info (originals)
/client-info/

# claude code
.claude/

# local-only docs
DESIGN_SYSTEM.md

# editors
.vscode/
.idea/
*.swp

# OS
Thumbs.db
Desktop.ini

# logs
*.log
